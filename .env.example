# ── AdGenAI / Astreli Configuration ───────────────────
# Copy this file to .env and fill in your API keys

# OpenAI (GPT-4o for scenario analysis & brand analysis)
OPENAI_API_KEY=sk-...

# Google Gemini (base scene image generation)
GEMINI_API_KEY=AIza...

# Fal.ai (video generation — Kling models via pay-as-you-go)
